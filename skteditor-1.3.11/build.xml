        </manifest>
      </jar>
      <delete file="dist/${help.name}.jar.classic" />
      <jar destfile="dist/${help.name}.jar.classic" 
-->
      <delete file="dist/${help.name}.jar" />
      <jar destfile="dist/${help.name}.jar" 
        compress="true">
        <fileset dir="docs" >
             <include name="help/**" />
             <exclude name="Tutorial/**" />
        </fileset>
<!-- doesn't need all-permissions but can't differ from jnlp  -->
        <manifest>
          <attribute name="Permissions" 
                     value="all-permissions" />
          <attribute name="Codebase" 
                     value="${codebase}" />
          <attribute name="Application-Name" 
                     value="SKTEditor Help" />
        </manifest>
      </jar>
  </target>

  <target name="build-help" depends="javahelp,jar-help"
     description="Executes the targets needed to build the applications help files.">
  </target>

  <target name="install" depends="build"
      description="Installs the application on rumba.gsfc.nasa.gov">
      <echo message="Installing the application ...."/>
      <echo message="Copying redistributable files...."/>
      <copy file="${jh-jar}" todir="dist" />
      <exec executable="./install.sh" os="Linux">
        <arg line="${install-dir}" />
      </exec>
  </target>

  <target name="ws-install" 
      description="Installs the application in a Java Web Start site on ubatuba.gsfc.nasa.gov">
      <echo message="Installing the application on its Web Start site...."/>
      <echo message="Signing files...."/>
      <exec executable="jarsigner">
        <arg value="-keystore ${keystore}" />
        <arg value="dist/${client.name}.jar.classic" />
        <arg value="${key-alias}" />
      </exec>
      <echo message="Copying files...."/>
      <copy todir="${ws-install-dir}">
         <fileset dir="dist/" >
         </fileset>
     </copy>
<!--
      <exec executable="ws-install.sh" os="SunOS">
        <arg line="${ws-install-dir}" />
      </exec>
-->
  </target>

