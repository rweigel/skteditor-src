                     value="SKTEditor" />
        </manifest>
      </jar>
  </target>

  <target name="build-big-jar" depends="set-os-props,jar-client"
     description="Builds a single jar containing everything">
    <echo message="Building a single jar containing everything" />
      <delete file="dist/${client.name}-all.jar" />
      <jar destfile="dist/${client.name}-all.jar" 
        compress="true" >
        <zipfileset excludes="*-INF/**" src="dist/${client.name}.jar" />
        <zipfileset excludes="*-INF/**" src="dist/${help.name}.jar" />
        <zipfileset excludes="*-INF/**" src="${cdf.jar}" />
        <zipfileset includes="**/*.class"
             src="${jh-jar}" />
        <zipfileset includes="**/*.class"
             src="${cdf.validation.dir}/cdf-validator.jar.classic" />
        <zipfileset includes="**/*.class"
             src="${cdf.validation.dir}/cdfutil-jaxb.jar.classic" />
<!--
        <manifest>
          <attribute name="Main-Class" 
                     value="gsfc.spdf.edit.guis.SKTEditor" />
          <attribute name="Permissions" 
                     value="all-permissions" />
          <attribute name="Codebase" 
                     value="${codebase}" />
          <attribute name="Application-Name" 
                     value="SKTEditor" />
        </manifest>
-->
      </jar>
  </target>

  <target name="build-mac-native" depends="build-big-jar"
    description="Builds self-contained application bundles">
    <echo message="Building self-contained application bundles" />
    <property name="app.name" value="SKTEditor" />
    <exec executable="javapackager" os="Mac OS X" failonerror="true">
      <arg line="-deploy" />
      <arg line="-native image" />
      <arg line="-srcdir dist" />
      <arg line="-srcfiles ${client.name}-all.jar" />
      <arg line="-outdir dist/native" />
      <arg line="-outfile skteditor" />
      <arg line="-appclass ${client-class}" />
      <arg line="-BmainJar=${client.name}-all.jar" />
      <arg line="-Bicon=resources/MacOsX/nasa-logo.icns" />
      <arg line="-BlicenseFile=docs/NASA_Open_Source_Agreement_1.3.txt" />
      <arg line="-Bmac.CDBundleIdentifier={client-class}" />
<!--
      <arg line="-Bmac.CFBundleVersion=${rev}" />
-->
      <arg line="-Bmac.CFBundleVersion=1.3.2" />
      <arg line="-Bmac.CFBundleName=${app.name}" />
      <arg line="-BsystemWide=false" />
    </exec>
    <copy todir="dist/native/bundles/${app.name}.app/Contents/MacOS">
      <fileset dir="${env.CDF_LIB}">
         <include name="libcdf.dylib" />
         <include name="libcdfNativeLibrary.jnilib" />
      </fileset>
      <fileset dir="${env.CDF_BIN}">
         <include name="*netCDF*" />
      </fileset>
    </copy>
    <chmod dir="dist/native/bundles/${app.name}.app/Contents/MacOS"
          perm="755" includes="*" />

    <!-- much of the following was copied from
         http://www.rkuntz.org/pmwiki.php?n=Code.AntDiskImage -->

    <property name="mountdir" value="/tmp"/>

    <!-- Delete previously created DMG -->
    <delete file="dist/native/bundles/${app.name}.dmg"
            quiet="yes" failonerror="false"/>

    <!-- Create a temporary Disk Image -->
    <exec executable="/usr/bin/hdiutil" os="Mac OS X" failonerror="true">
      <arg value="create"/>
      <arg value="-srcfolder"/>
      <arg value="dist/native/bundles/${app.name}.app"/>
      <arg value="-volname"/>
      <arg value="${app.name}"/>
      <arg value="-ov"/>
      <arg value="dist/native/bundles/${app.name}-tmp.dmg"/>
      <arg value="-format"/>
      <arg value="UDRW"/>
    </exec>

    <!-- Attach the temporary image -->
    <exec executable="/usr/bin/hdiutil" os="Mac OS X" failonerror="true">
      <arg value="attach"/>
      <arg value="dist/native/bundles/${app.name}-tmp.dmg"/>
      <arg value="-mountroot"/>
      <arg value="${mountdir}/"/>
    </exec>

    <!-- Copy the background, the volume icon and DS_Store files -->
<!--
    <mkdir dir="${mountdir}/${app.name}/.background"/>
    <copy file="background.png"
          tofile="${mountdir}/${app.name}/.background/background.png"
          overwrite="true"/>
    <copy file="VolumeIcon.icns"
          tofile="${mountdir}/${app.name}/.VolumeIcon.icns"
          overwrite="true"/>
-->
    <copy file="resources/MacOsX/nasa-logo.icns"
          tofile="${mountdir}/${app.name}/.VolumeIcon.icns"
          overwrite="true"/>
    <copy file="resources/MacOsX/DS_Store"
          tofile="${mountdir}/${app.name}/.DS_Store"
          overwrite="true"/>

    <!-- Indicate that we want a custom icon -->
<!--
    <exec executable="/Developer/Tools/SetFile" os="Mac OS X">
      <arg value="-a"/>
      <arg value="C"/>
      <arg value="${mountdir}/${app.name}"/>
    </exec>
-->

    <!-- Add a symbolic link to the Applications directory -->
    <symlink link="${mountdir}/${app.name}" resource="/Applications"/>

    <!-- Detach the temporary image -->
    <exec executable="/usr/bin/hdiutil" os="Mac OS X" failonerror="true">
      <arg value="detach"/>
      <arg value="${mountdir}/${app.name}"/>
    </exec>

    <!-- Compress it to a new image and delete the temporary 
         Note: this does not work on macOS 10.13 and APFS.
    <exec executable="/usr/bin/hdiutil" os="Mac OS X" failonerror="true">
      <arg value="convert"/>
      <arg value="-debug"/>
      <arg value="dist/native/bundles/${app.name}-tmp.dmg"/>
      <arg value="-format"/>
      <arg value="UDZO"/>
      <arg value="-o"/>
      <arg value="dist/native/bundles/${app.name}.dmg"/>
    </exec>
    <delete file="dist/native/bundles/${app.name}-tmp.dmg"
            quiet="yes" failonerror="false"/>
    -->
    <move file="dist/native/bundles/${app.name}-tmp.dmg"
        tofile="dist/native/bundles/${app.name}.dmg" />

    <!-- This doesn't seem to work on an APFS system
    <exec executable="bin/make-diskimage" os="Mac OS X">
        <arg value="dist/native/bundles/${osx.app.name}.dmg" />
        <arg value="dist/native/bundles/SKTEditor.app" />
        <arg value="${osx.app.name}" />
        <arg value="-null-" />
        <arg value="resources/MacOsX/DS_Store" />
        <arg value="docs/nasaball.png" />
    </exec>
    -->
  </target>

  <target name="build-jnlp-jars" depends="build"
     description="Builds the jar files for the jnlp application" >
    <echo message="Building the jar files for a jnlp deployment" />
    <input message="Enter keystore password"
           addproperty="keystore.pass" />
    <input message="Enter alias password"
           addproperty="key.pass" />
    <antcall target="build-alt-jars" >
      <param name="file.param" value="dist/${client.name}" />
      <param name="keystore.pass.param" value="${keystore.pass}" />
      <param name="key.pass.param" value="${key.pass}" />
    </antcall>
    <antcall target="build-alt-jars" >
      <param name="file.param" value="dist/${help.name}" />
      <param name="keystore.pass.param" value="${keystore.pass}" />
      <param name="key.pass.param" value="${key.pass}" />
    </antcall>
  </target>

  <target name="build-alt-jars" depends="set-os-props,set-keystore"
     description="Builds alternative (gzip, pack200) versions of a jar" >
    <echo message="Building alternative versions of ${file.param}." />
    <exec executable="${pack200}" >
      <arg line="--repack" />
      <arg line="${file.param}.nozip.jar" />
    </exec>
    <signjar jar="${file.param}.jar.classic"
             keystore="${keystore}"
             storepass="${keystore.pass}"
             keypass="${key.pass}"
             tsaurl="${tsa.url}"
             alias="ssdoo-key" />
    <signjar jar="${file.param}.nozip.jar"
             keystore="${keystore}"
             storepass="${keystore.pass}"
             keypass="${key.pass}"
             tsaurl="${tsa.url}"
             alias="ssdoo-key" />
    <gzip src="${file.param}.nozip.jar" destfile="${file.param}.jar.gz" />
    <exec executable="${pack200}" >
      <arg line="${file.param}.jar.pack.gz" />
      <arg line="${file.param}.nozip.jar" />
    </exec>
  </target>


  <target name="init-osx" depends="prepare"
     description="Creates the OS X application bundle directories" >
     <echo message="Creating the required directories...." />
     <mkdir dir="dist/MacOsX/${osx.app.name}.app" />
     <mkdir dir="dist/MacOsX/${osx.app.name}.app/Contents" />
     <mkdir dir="dist/MacOsX/${osx.app.name}.app/Contents/MacOS" />
     <mkdir dir="dist/MacOsX/${osx.app.name}.app/Contents/Resources" />
     <mkdir dir="dist/MacOsX/${osx.app.name}.app/Contents/Resources/Java" />
  </target>

  <target name="build-osx-j6app" depends="init-osx,build"
      description="Builds an OS X application bundle">
    <echo message="Building OS X application bundle...."/>
    <!-- build .../MacOS  -->
<!-- If JavaApplicationStub cannot be made to set the necessary
     environment variables, consider using a shell script.
    <copy file="resources/MacOsX/JavaApplicationStub.sh"
          todir="dist/MacOsX/${osx.app.name}.app/Contents/MacOS" />
-->
    <copy file="/System/Library/Frameworks/JavaVM.framework/Versions/Current/Resources/MacOS/JavaApplicationStub"
          todir="dist/MacOsX/${osx.app.name}.app/Contents/MacOS" />
    <copy todir="dist/MacOsX/${osx.app.name}.app/Contents/MacOS">
      <fileset dir="${cdf.bin.dir}">
        <include name="skeleton*" />
      </fileset>
    </copy>
    <chmod dir="dist/MacOsX/${osx.app.name}.app/Contents/MacOS"
          perm="755" includes="*" />
    <!-- build .../Contents  -->
    <copy todir="dist/MacOsX/${osx.app.name}.app/Contents">
      <fileset dir="resources/MacOsX">
        <include name="Info.plist" />
        <include name="PkgInfo" />
      </fileset>
    </copy>
<!--
    <copy file="resources/MacOsX/DS_Store"
          tofile="dist/MacOsX/.DS_Store" />
    <copy file="/Library/Application Support/Apple/Developer Tools/Project Templates/Java/Java Swing Application/GenericJavaApp.icns"
          todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources" />
-->
    <!-- build .../Resources  -->
    <copy file="docs/nasaball.png"
          todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources" />
    <!-- build .../Resources  -->
    <copy todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources/Java">
      <fileset dir="dist" >
        <include name="*.jar.classic" />
      </fileset>
      <mapper type="regexp" from="^(.*).classic$$" to="\1" />
    </copy>
    <copy todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources/Java">
      <fileset dir="${cdf.lib.dir}" >
        <include name="cdfjava.jar" />
      </fileset>
      <fileset dir="${cdf.validation.dir}" >
        <include name="*.jar" />
      </fileset>
    </copy>
    <copy file="${jh-jar}"
          todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources/Java" />
    <!-- be certain that following CDF libraries match the 32/64 bitness
         of the JavaApplicationStub we are using. -->
    <copy todir="dist/MacOsX/${osx.app.name}.app/Contents/Resources">
      <fileset dir="${cdf.lib.dir}" >
        <include name="*.dylib" />
        <include name="*.jnilib" />
      </fileset>
      <fileset dir="${cdf.base.dir}" >
        <include name="*.txt" />
      </fileset>
    </copy>
    <chmod dir="dist/MacOsX/${osx.app.name}.app/Contents/Resources"
           perm="755">
      <fileset dir="${cdf.lib.dir}" >
        <include name="*.dylib" />
        <include name="*.jnilib" />
      </fileset>
    </chmod>
    <!-- build .../Contents  -->
    <chmod file="dist/MacOsX/${osx.app.name}.app/Contents/Resources/libcdfNativeLibrary.jnilib"
          perm="755" />
    <exec executable="/Developer/Tools/SetFile">
        <arg line="-a B dist/MacOsX/${osx.app.name}.app"/>
    </exec>
  </target>

  <target name="build-osx-dmg" depends="build-osx-j6app"
      description="Builds a OS X disk image">
     <echo message="Building OS X disk image...."/>
    <delete file="dist/${osx.app.name}.dmg" />
    <exec executable="bin/make-diskimage">
        <arg value="dist/${osx.app.name}.dmg" />
        <arg value="dist/MacOsX" />
        <arg value="${osx.app.name}" />
        <arg value="-null-" />
<!--
        <arg value="resources/MacOsX/DS_Store" />
        <arg value="docs/nasaball.png" />
-->
    </exec>
  </target>

<!-- requires JDK 1.7 -->
  <target name="build-osx-app"
       depends="init-osx,build" if="osx" >
    <bundleapp outputdirectory="dist"
        name="SktEditor"
        displayname="ISTP Skeleton CDF Editor"
        identifier="${client-class}"
        mainclassname="${client-class}">
        <runtime dir="${env.JAVA_HOME}" />
    </bundleapp>
    <!-- 
      The following is used because MacAppBundler 1.0 did not support
      multiple files in classpath and librarypath elements.  Both
        <classpath refid="run.classpath" />
        <librarypath refid="cdf.librarypath" />
      and
        <property name="prop.run.classpath" refid="run.classpath" />
        <property name="prop.cdf.librarypath" refid="cdf.librarypath" />
        ...
        <classpath file="{prop.run.classpath}" />
        <librarypath file="{prop.cdf.librarypath}" />
      and
        <classpath>
          <fileset ... />
        </classpath>
        <librarypath>
          <fileset ... />
        </librarypath>
      were tried with no success.
    -->
    <copy todir="${dist}/SktEditor.app/Contents/Java">
      <fileset file="${cdf.jar}" />
      <fileset dir="${cdf.validation.dir}">
        <include name="*.jar" />
      </fileset>
      <fileset file="${jh-jar}" />
      <fileset dir="${dist}">
<!--
        <include name="*.jar.classic" />
-->
        <include name="*.jar" />
      </fileset>
    </copy>
    <copy todir="${dist}/SktEditor.app/Contents/MacOS">
      <fileset dir="${cdf.lib.dir}">
        <include name="*.jnilib" />
        <include name="*.dylib" />
      </fileset>
    </copy>
    <chmod perm="755">
      <fileset dir="${dist}/SktEditor.app/Contents/MacOS">
        <include name="*.jnilib" />
        <include name="*.dylib" />
      </fileset>
    </chmod>
  </target>
<!-- end requires JDK 1.7 -->

  <target name="run" depends="set-os-props,set-cdf-jar"
     description="Runs the example client">
     <echo message="Running the ${client-class} program:" />
     <echo message="java -classpath dist/${client.name}.jar:dist/${help.name}.jar:${cdf.jar}:${jh-jar} ${client-class} " />
     <echo message=" " />
      <java fork="on" classname="${client-class}" >
        <classpath refid="run.classpath" />
        <jvmarg value="-ea:gsfc..." />
        <!-- for aarch64 macos 13, XQuartz 2.8.5 -->
        <jvmarg value="-Dsun.java2d.xrender=false" />
        <jvmarg value="-Dsun.java2d.pmoffscreen=false" />
<!-- JDK 9
        <jvmarg value="- -add-modules=java.xml.bind" />
-->
<!--
        <jvmarg value="-Xcheck:jni" />
        <sysproperty key="suppress" value="NON_STANDARD_FILLVAL,MISSING_SPASE_ID" />
-->
        <arg line="${test.files}" />
<!--
        <arg line="-o ${notes.file} ${test.files}" />
-->
<!--
        <sysproperty key="swing.defaultlaf" 
                   value="javax.swing.plaf.nimbus.NimbusLookAndFeel" />
-->
        <sysproperty key="apple.laf.useScreenMenuBar" 
                   value="true" />
        <sysproperty key="com.apple.mrj.application.apple.menu.about.name" 
                   value="${osx.app.name}" />
        <sysproperty key="cdf.checksum" value="${cdf.checksum.value}" />
<!--
        <sysproperty key="cdf.validation.criteria" 
                   value="${cdf.validation.file}" />
-->
<!-- uncomment if necessary or to test functionality
        <sysproperty key="jnlp.cdf.base" value="${cdf.base.dir}" />
        <sysproperty key="cdf.base" value="${cdf.base.dir}" />
        <sysproperty key="cdf.bin" value="${cdf.bin.dir}" />
-->
        <sysproperty key="skteditor.cdf.debug" value="false" />
      </java>
  </target>


