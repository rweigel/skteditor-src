-->
      <delete file="dist/${client.name}.jar" />
      <jar destfile="dist/${client.name}.jar" 
        compress="true" >
        <fileset dir="${build}/client" >
        </fileset>
        <manifest>
          <attribute name="Main-Class" 
                     value="gsfc.spdf.edit.guis.SKTEditor" />
          <attribute name="Class-Path" 
                     value="extensions/cdfjava.jar extensions/jh.jar extensions/skteditor-help.jar extensions/cdf-validator.jar extensions/cdfutil-jaxb.jar extensions/jakarta.activation.jar extensions/jakarta.xml.bind-api.jar extensions/jaxb-osgi.jar" />
          <attribute name="Permissions" 
                     value="all-permissions" />
          <attribute name="Codebase" 
                     value="${codebase}" />
