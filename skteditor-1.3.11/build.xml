  <target name="build-pkgs" depends="build,pkg-source,pkg-app"
     description="Builds all distribution files except Mac OS 8/9 files.">
  </target>


  <target name="pkg-source"
    description="Packages the source code">
    <echo message="Packaging the source code...." />
    <delete file="dist/${src-pkg-name}.zip" />
    <zip zipfile="dist/${src-pkg-name}.zip" >
      <zipfileset dir="src" includes="**/*.java,**/*.html"
                  prefix="${pkg-name}/src" />
      <zipfileset dir="docs/help" includes="**/*"
                  prefix="${pkg-name}/docs/help" />
      <zipfileset dir="web" includes="license.html"
                  prefix="${pkg-name}/web" />
      <zipfileset dir="resources" 
                  includes="*.properties,*.resources,images/**/*"
                  prefix="${pkg-name}/resources" />
      <zipfileset dir="." includes="build.properties,build.xml,targets.xml"
                  prefix="${pkg-name}" />
    </zip>
    <checksum file="dist/${src-pkg-name}.zip" algorithm="${file.hash}" />
  </target>
        

  <target name="pkg-app" depends="build"
    description="Packages a standalone version of the application">
    <echo message="Packaging a standalone version of the application...." />
    <delete file="dist/${app-name}.zip" />
    <zip zipfile="dist/${app-name}.zip" >
      <zipfileset dir="dist" includes="${client.name}.jar"
          fullpath="${pkg-name}/${client.name}.jar" />
      <zipfileset dir="dist" includes="${help.name}.jar"
          fullpath="${pkg-name}/extensions/${help.name}.jar" />
      <zipfileset dir="${jh-dir}/javahelp/lib" includes="jh.jar"
          prefix="${pkg-name}/extensions" />
      <zipfileset file="${cdf.jar}"
          prefix="${pkg-name}/extensions" />
      <zipfileset dir="${cdf.validation.dir}" 
          includes="cdf-validator.jar.classic"
          fullpath="${pkg-name}/extensions/cdf-validator.jar" />
      <zipfileset dir="${cdf.validation.dir}" 
          includes="cdfutil-jaxb.jar.classic"
          fullpath="${pkg-name}/extensions/cdfutil-jaxb.jar" />
      <zipfileset dir="${cdasws.dir}" 
          includes="cdasWebServices-jaxb.jar"
          fullpath="${pkg-name}/extensions/cdasWebServices-jaxb.jar" />
      <!-- For JDK 11.  The following zipfileset is a duplicate of 
           jaxb.classpath but I do not know how to use jaxb.classpath 
           here to get the files. -->
      <zipfileset dir="${javaee.mod}" prefix="${pkg-name}/extensions" >
        <include name="jakarta.xml.bind-api.jar" />
        <include name="jakarta.activation.jar" />
        <include name="jaxb-osgi.jar" />
      </zipfileset>
<!-- for linux testing (on personal computer)
<zipfileset dir="${cdf.base.dir}/lib" prefix="${pkg-name}" >
  <include name="*.so" />
</zipfileset>
-->
    </zip>
    <checksum file="dist/${app-name}.zip" algorithm="${file.hash}" />
  </target>


<!--
  <target name="pkg-release" depends="build-jnlp-jars,pkg-source,pkg-app"
-->
  <target name="pkg-release" depends="build,pkg-source,pkg-app"
    description="Creates a zip file containing the entire release">
    <echo message="Generating release-specific pages..." />
    <copy file="web/SKTEditorTemplate.html"
        tofile="web/index.html"
        overwrite="true">
      <filterset begintoken="%" endtoken="*">
        <filter token="MSI-NAME" value="${msi-name}" />
      </filterset>
      <filterset begintoken="%" endtoken="*">
        <filter token="DMG-NAME" value="${dmg-name}" />
      </filterset>
      <filterset begintoken="%" endtoken="*">
        <filter token="SOURCE-ARCHIVE" value="${src-pkg-name}" />
      </filterset>
      <filterset begintoken="%" endtoken="*">
        <filter token="FILE-HASH" value="${file.hash}" />
      </filterset>
    </copy>
    <copy file="web/skteditorTemplate.jnlp"
          tofile="web/skteditor.jnlp"
          overwrite="true" >
      <!-- the following filterset may no longer be needed -->
      <filterset begintoken="%" endtoken="*">
        <filter token="CODEBASE" value="${deploy.url}" />
      </filterset>
    </copy>
    <copy file="web/installation/ManualEditorTemplate.html"
        tofile="web/installation/ManualEditor.html"
        overwrite="true">
      <filterset begintoken="%" endtoken="*">
        <filter token="APP-NAME" value="${app-name}" />
      </filterset>
      <filterset begintoken="%" endtoken="*">
        <filter token="FILE-HASH" value="${file.hash}" />
      </filterset>
    </copy>
    <echo message="Creating release archive..." />
    <delete file="dist/${pkg-name}.zip" />
    <zip zipfile="dist/${pkg-name}.zip" >
      <zipfileset dir="dist" prefix="${pkg-name}" >
        <include name="*.jar" />
        <include name="*.jar.classic" />
        <include name="*.jar.gz" />
        <include name="*.jar.pack.gz" />
      </zipfileset>
      <zipfileset dir="docs" prefix="${pkg-name}/docs" >
        <include name="ReleaseNotes.html" />
        <include name="nasaball.png" />
        <include name="NASA_Open_Source_Agreement*.txt" />
      </zipfileset>
      <zipfileset dir="web" prefix="${pkg-name}" >
        <include name="**/*.html" />
        <include name="**/*.txt" />
        <include name="**/*.gif" />
        <include name="**/*.jpg" />
        <include name="**/*.png" />
        <include name="**/*.jnlp" />
        <exclude name="**/cdf.jnlp" />
        <exclude name="**/*Template.html" />
      </zipfileset>
      <zipfileset dir="${jh-dir}/javahelp/lib" includes="jh.jar"
                  prefix="${pkg-name}/JavaHelp" />
      <zipfileset dir="dist" prefix="${pkg-name}/src" >
        <include name="${src-pkg-name}*" />
      </zipfileset>
      <zipfileset dir="dist" prefix="${pkg-name}" >
        <include name="**/${app-name}*" />
      </zipfileset>
    </zip>
    <checksum file="dist/${pkg-name}.zip" algorithm="${file.hash}" />
  </target>


  <target name="clean" 
     description="Removes the build and dist directories">
    <delete dir="${build}" />
    <delete dir="dist" />
    <delete dir="docs/api" />
  </target>

  <target name="javadoc-check" depends="set-os-props"
     description="Checks javadoc documentation ">
     <echo message="Generating Doc Check Reports ...."/>
     <mkdir dir="docs/api-check" />
     <javadoc
              doclet="com.sun.tools.doclets.doccheck.DocCheck"
              docletpath="${user.home}/opt/doccheck1.2b2/doccheck.jar"
              defaultexcludes="yes"
              destdir="docs/api-check"
              author="true"
              version="true"
              private="true"
              additionalparam="-breakiterator -evident 5">
       <classpath>
         <pathelement location="${jh-jar}" />
         <pathelement location="${apple-jar}" />
         <path refid="cdf.classpath" />
         <path refid="cdf.validation.classpath" /> 
         <path refid="cdasws.classpath" /> 
       </classpath>
       <packageset dir="src" defaultexcludes="yes">
         <include name="gsfc/spdf/istp/**" />
         <include name="gsfc/spdf/cdf/**" />
         <exclude name="gsfc/spdf/cdf/tools/**" />
         <exclude name="gsfc/spdf/istp/tools/CleanAttributes.java" />
         <exclude name="gsfc/spdf/istp/tools/GetAttributes.java" />
         <exclude name="gsfc/spdf/istp/tools/CDFCheck.java" />
       </packageset>
     </javadoc>
  </target>

  <target name="javadoc" depends="prepare, set-os-props"
     description="Creates javadoc documentation from the source code">
<!--
              excludepackagenames="gsfc.spdf.cdf.tools"
-->
     <javadoc packagenames="gsfc.spdf.*"
              sourcepath="src"
              defaultexcludes="yes"
              destdir="docs/api"
              author="true"
              version="true"
              private="true"
              use="true"
              windowtitle="ISTP CDF Skeleton Editor">
        <classpath>
          <pathelement location="${cdf.jar}" />
          <pathelement location="${jh-jar}" />
          <pathelement location="${apple-jar}" />
<!--  -->
          <path refid="cdf.validation.classpath" /> 
          <path refid="jaxb.classpath" />
          <path refid="cdasws.classpath" /> 
<!--  -->
        </classpath>
       <packageset dir="src" defaultexcludes="yes">
         <include name="gsfc/spdf/istp/tools/**" />
         <exclude name="gsfc/spdf/istp/tools/CleanAttributes.java" />
         <exclude name="gsfc/spdf/istp/tools/GetAttributes.java" />
         <exclude name="gsfc/spdf/istp/tools/CDFCheck.java" />
       </packageset>
       <bottom><![CDATA[<a href="mailto:NASA-SPDF-Support@nasa.onmicrosoft.com?subject=SKTEditor%20Feedback">SKTEditor Feedback</a>.<br><br>Copyright &#169; 2000-2024 United States Government as represented by the National Aeronautics and Space Administration.  No copyright is claimed in the United States under Title 17, U.S.Code.  All Other Rights Reserved.]]></bottom>
     </javadoc>
  </target>

  <target name="javahelp" depends="set-os-props"
     description="Creates javahelp full-text search database used by the JavaHelp system">
     <echo message="Generating dynamic content..." />
     <tstamp>
         <format property="BUILD_TIME" pattern="yyyy/MM/dd hh:mm:ss Z" />
     </tstamp>
     <copy file="${help-dir}/UsersGuide/AboutTemplate.html"
           toFile="${help-dir}/UsersGuide/About.html" overwrite="true" >
       <filterset begintoken="%" endtoken="*">
         <filter token="VERSION" value="${rev}" />
         <filter token="DATE" value="${BUILD_TIME}" />
         <filter token="BUILD_PLATFORM" 
                 value="${os.name} ${os.arch} ${os.version}" />
         <filter token="BUILD_COMPILER" value="${java.version}" />
         <filter token="BUILD_TARGET" value="${java.target}" />
       </filterset>
     </copy>
     <copy file="resources/images/LICENSE" 
           toFile="${help-dir}/UsersGuide/licenses/jlfgr-license.txt" />
     <copy file="web/license.html" 
           toFile="${help-dir}/UsersGuide/licenses/license.html" />
     <copy file="${jh-dir}/LICENSE.html" 
           toFile="${help-dir}/UsersGuide/licenses/jh-license.html" />
     <echo message="Running ${jhindexer}: " />
     <exec dir="${help-dir}" executable="${jhindexer}">
       <arg line="UsersGuide Tutorial"/>
     </exec>
  </target>

  <target name="jar-help" depends="prepare,javahelp"
      description="Builds the JAR file that contains the help contents">
      <echo message="Building the help JAR  file...."/>
