<project name="ISTP CDF Skeleton Editor" default="build" basedir=".">

  <property file="build.properties"/>

     <property environment="env" />
     <property name="cdf.base.dir" value="${env.CDF_BASE}" />
     <property name="cdf.bin.dir" value="${env.CDF_BIN}" />
<!-- used with beta versions of cdf  
     <property name="cdf.lib.dir" value="lib" />
-->
     <property name="cdf.lib.dir" value="${env.CDF_LIB}" />
     <property name="cdf.jar" value="${cdf.lib.dir}/cdfjava.jar" />
     <property name="pack200" value="${java.home}/bin/pack200" />

  <presetdef name="javac">
    <javac includeantruntime="false" />
  </presetdef>

<!-- requires JDK 1.7 
  <taskdef name="bundleapp"
         classname="com.oracle.appbundler.AppBundlerTask"
         classpath="lib/MacAppBundler/appbundler-1.0.jar" />
 end requires JDK 1.7 -->

  <path id="cdf.classpath">
    <pathelement location="${cdf.jar}" />
  </path>

  <path id="cdf.validation.classpath">
    <fileset dir="${cdf.validation.dir}">
      <include name="*.jar" />
    </fileset>
  </path>

  <path id="cdasws.classpath">
    <fileset dir="${cdasws.dir}">
      <include name="*.jar" />
    </fileset>
  </path>

  <path id="cdf.librarypath">
    <fileset dir="${cdf.lib.dir}">
      <!-- 
      This pathref is currently only used in the build-osx-app target
      so it only needs OS X CDF native libraries (do not need *.so, 
      *.dll).
      -->
      <include name="*.so" />
      <include name="*.jnilib" />
      <include name="*.dylib" />
    </fileset>
  </path>

  <!-- jdk 11 -->
  <path id="jaxb.classpath">
    <fileset dir="${javaee.mod}">
      <include name="jakarta.xml.bind-api.jar" />
      <include name="jakarta.activation.jar" />
      <include name="jaxb-osgi.jar" />
      <!-- jakarta ee 10 
      <include name="jakarta.activation-api.jar" />
      -->
    </fileset>
  </path>
  <!-- end jdk 11 -->

  <target name="set-os-props"
     description="Sets OS dependant properties" >
     <exec executable="hostname" outputproperty="hostname" />
     <condition property="script-suffix" value="bat">
        <os family="windows"/>
     </condition>
     <condition property="script-suffix" value="sh">
        <not>
           <os family="windows"/>
        </not>
     </condition>
     <condition property="jh-dir" value="${jh.dir.unix}">
        <os family="unix" />
     </condition>
     <condition property="osx">
        <os name="Mac OS X" />
     </condition>
<!--
     <condition property="jh-dir" value="${jh.dir.solaris}">
        <os name="SunOS" />
     </condition>
     <condition property="jh-dir" value="${jh.dir.macosx}">
        <os name="Mac OS X" />
     </condition>
-->
     <condition property="jh-dir" value="${jh-dir-win}">
        <os family="windows"/>
     </condition>
     <condition property="jhindexer" value="${jh-dir}/javahelp/bin/jhindexer.bat">
        <os family="windows"/>
     </condition>
     <condition property="jhindexer" value="${jh-dir}/javahelp/bin/jhindexer">
        <os family="unix"/>
     </condition>
     <property name="jh-jar" value="${jh-dir}/javahelp/lib/jh.jar" />

    <path id="jh.classpath">
      <pathelement location="${jh-jar}" />
    </path>

    <path id="compile.classpath">
      <path refid="cdf.classpath" />
<!--  -->
      <path refid="cdf.validation.classpath" /> 
      <path refid="cdasws.classpath" /> 
<!--  -->
      <path refid="jh.classpath" />
      <!-- jdk 11 -->
      <path refid="jaxb.classpath" />
      <!-- end jdk 11 -->
    </path>

    <path id="run.classpath">
      <path refid="cdf.classpath" />
<!--  -->
      <path refid="cdf.validation.classpath" /> 
      <path refid="cdasws.classpath" /> 
<!--  -->
      <path refid="jh.classpath" />
      <!-- jdk 11 -->
      <path refid="jaxb.classpath" />
      <!-- end jdk 11 -->
      <fileset dir="${dist}">
<!--
        <include name="*.jar.classic" />
-->
        <include name="*.jar" />
      </fileset>
    </path>
  </target>

  <target name="set-keystore"
     description="Sets the OS dependent keystore property" >
     <condition property="keystore" value="${keystore-solaris}">
        <os name="SunOS"/>
     </condition>
     <condition property="keystore" value="${keystore-macosx}">
        <os name="Mac OS X"/>
     </condition>
     <condition property="keystore" value="${keystore-win}">
        <os family="windows"/>
     </condition>
  </target>

  <!-- The following target may still be of use on Windows or Unix
       platforms where the cdfjava.jar isn't in the CDF_LIB directory
       but isn't used with CDF 3.0 on ncssparc or ubatuba -->
  <target name="set-cdf-jar" depends="set-os-props"
     description="Sets the OS dependent cdf-jar property" >
     <condition property="cdf-jar" value="${cdf-jar-win}">
        <os family="windows"/>
     </condition>
  </target>

  <target name="prepare" 
     description="Creates the build and dist directories" >
     <echo message="Creating the required directories...." />
     <mkdir dir="${build}/client/resources/" />
     <mkdir dir="dist/" />
     <mkdir dir="dist/native" />
     <mkdir dir="docs/api/" />
     <mkdir dir="docs/help/UsersGuide/licenses/" />
  </target>

  <target name="compile-client" depends="prepare,set-os-props,set-cdf-jar"
      description="Compiles the client-side source code"  >
      <echo message="Compiling the client source code...."/>
      <javac
         target="${java.target}"
         source="${java.src}"
         srcdir="src"
         destdir="${build}/client" >
        <classpath refid="compile.classpath" />
<!--
         extdirs="${java.ext.dirs}"
        <compilerarg value="-Xlint" />
-->
        <bootclasspath>
          <pathelement path="${java.target.bootclasspath}" />
        </bootclasspath>
        <extdirs>
          <pathelement path="${java.target.extdirs}" />
        </extdirs>
        <compilerarg value="-g:source,lines,vars" /> 
        <compilerarg value="-Xlint:unchecked" />
        <exclude name="**/tools/CDFCompare.java" />
        <exclude name="**/tools/CDFConvert.java" />
        <exclude name="**/tools/CDFDir.java" />
        <exclude name="**/tools/CDFDump.java" />
        <exclude name="**/tools/CDFInquire.java" />
        <exclude name="**/tools/CDFRemoteLibrary.java" />
        <exclude name="**/tools/CDFStats.java" />
        <exclude name="**/tools/CDFToolsDriver.java" />
        <exclude name="**/tools/SimpleFileFilter.java" />
        <exclude name="**/tools/SkeletonTable.java" />
        <exclude name="**/tools/SkeletonCDF.java" />
      </javac>
  </target>


  <target name="jar-client" 
      description="Builds the JAR file that contains the client">
     <echo message="Building the client JAR  file...."/>
     <echo message="Generating dynamic content..." />
     <tstamp>
         <format property="BUILD_TIME" pattern="yyyy/MM/dd hh:mm:ss Z" />
     </tstamp>
     <copy file="resources/default.properties"
           toFile="${build}/client/resources/default.properties"
           overwrite="true" >
       <filterset begintoken="%" endtoken="*">
         <filter token="VERSION" value="${rev}${client-version}" />
         <filter token="BUILD_PLATFORM" 
                 value="${os.name} ${os.arch} ${os.version}" />
         <filter token="BUILD_COMPILER" value="${java.version}" />
         <filter token="BUILD_DATE" value="${BUILD_TIME}" />
       </filterset>
     </copy>
     <copy todir="${build}/client/resources/">
         <fileset dir="resources/" >
           <exclude name="resources/default.properties" />
         </fileset>
     </copy>
     <!-- for web site -->
     <copy file="web/skteditorTemplate.jnlp"
           tofile="web/skteditor.jnlp"
           overwrite="true" >
       <!-- the following filterset may no longer be needed -->
       <filterset begintoken="%" endtoken="*">
         <filter token="CODEBASE" value="${deploy.url}" />
       </filterset>
     </copy>
     <!-- for Java 1.7 -->
     <copy file="web/skteditorTemplate.jnlp"
           tofile="${build}/client/JNLP-INF/APPLICATION_TEMPLATE.JNLP"
           overwrite="true" >
       <!-- the following filterset may no longer be needed -->
       <filterset begintoken="%" endtoken="*">
         <filter token="CODEBASE" value="*" />
       </filterset>
     </copy>
     <fixcrlf srcdir="${build}/client/JNLP-INF"
         eol="unix"
         includes="**/*.JNLP"
     />
<!--
     <copy todir="${build}/client/">
         <fileset dir="src" includes="*.txt" />
     </copy>
-->
      <!-- The nozip jar file is named .nozip.jar instead of .jar.nozip
           (which would be consistent with the .jar.gz and .jar.pack.gz)
           to satisfy pack200 -->
<!--
      <delete file="dist/${client.name}.nozip.jar" />
      <jar destfile="dist/${client.name}.nozip.jar" 
        compress="false" >
        <fileset dir="${build}/client" >
        </fileset>
        <manifest>
          <attribute name="Built-By" value="${user.name}" />
          <attribute name="Main-Class" 
                     value="gsfc.spdf.edit.guis.SKTEditor" />
          <attribute name="Class-Path" 
                     value="extensions/cdfjava.jar extensions/jh.jar extensions/skteditor-help.jar extensions/cdf-validator.jar extensions/cdfutil-jaxb.jar extensions/jakarta.activation.jar extensions/jakarta.xml.bind-api.jar extensions/jaxb-osgi.jar" />
          <attribute name="Permissions" 
                     value="all-permissions" />
